# test-coverage-mcp Environment Variables Example

# Provider Authentication
CODECOV_TOKEN=your-codecov-token-here
COVERALLS_TOKEN=your-coveralls-token-here

# Server Configuration
TRANSPORT=sse
HOST=0.0.0.0
PORT=8000
LOG_LEVEL=info

# Development
RELOAD=false
INTEGRATED=true

# Python Configuration
PYTHONDONTWRITEBYTECODE=1
PYTHONUNBUFFERED=1
